                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="leaf_deny2" value="&lt;b&gt;DENY&lt;/b&gt;&lt;br&gt;[1 instance]&lt;br&gt;0 Approve, 1 Deny&lt;br&gt;H = 0.000 (pure)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontColor=#B71C1C;fontSize=11;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1350" y="710" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="calc_cs" value="&lt;b&gt;IG(Credit Score) Calculation:&lt;/b&gt;&lt;br&gt;poor  (5/10): 0 Approve, 5 Deny  → H = 0.000  ← pure!&lt;br&gt;good  (5/10): 4 Approve, 1 Deny  → H = −(4/5)log₂(4/5) − (1/5)log₂(1/5) = 0.722&lt;br&gt;Weighted Avg H = (5/10)×0.000 + (5/10)×0.722 = 0.361&lt;br&gt;&lt;b&gt;IG(Credit Score) = 0.971 − 0.361 = 0.610 ✓ HIGHEST → ROOT&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontColor=#212121;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="20" y="870" width="620" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="calc_income" value="&lt;b&gt;IG(Income | Credit Score = good) Calculation:&lt;/b&gt;&lt;br&gt;high   (2/5): 2 Approve, 0 Deny → H = 0.000  ← pure!&lt;br&gt;medium (2/5): 2 Approve, 0 Deny → H = 0.000  ← pure!&lt;br&gt;low    (1/5): 0 Approve, 1 Deny → H = 0.000  ← pure!&lt;br&gt;Weighted Avg H = 0 + 0 + 0 = 0.000&lt;br&gt;&lt;b&gt;IG(Income) = 0.722 − 0.000 = 0.722 → Splits perfectly!&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="820" y="870" width="620" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="calc_income_root" value="&lt;b&gt;IG(Income) at root — why NOT chosen:&lt;/b&gt;&lt;br&gt;high   (3/10): 2 Approve, 1 Deny → H = 0.918&lt;br&gt;medium (4/10): 2 Approve, 2 Deny → H = 1.000&lt;br&gt;low    (3/10): 0 Approve, 3 Deny → H = 0.000&lt;br&gt;Weighted H = (3/10)×0.918 + (4/10)×1.000 + (3/10)×0.000 = 0.675&lt;br&gt;&lt;b&gt;IG(Income) = 0.971 − 0.675 = 0.296  &lt; IG(Credit Score) = 0.610&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="20" y="1010" width="620" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="calc_employed" value="&lt;b&gt;IG(Employed) at root — why NOT chosen:&lt;/b&gt;&lt;br&gt;yes (5/10): 3 Approve, 2 Deny → H = 0.971&lt;br&gt;no  (5/10): 1 Approve, 4 Deny → H = 0.722&lt;br&gt;Weighted H = (5/10)×0.971 + (5/10)×0.722 = 0.847&lt;br&gt;&lt;b&gt;IG(Employed) = 0.971 − 0.847 = 0.124  &lt; IG(Credit Score) = 0.610&lt;/b&gt;&lt;br&gt;Not used in final tree." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#AD1457;fontColor=#880E4F;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="820" y="1010" width="620" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="&lt;b&gt;Legend:&lt;/b&gt;  Ellipse = Decision Node  |  Rounded rect = Leaf Node  |  Green = APPROVE  |  Red = DENY  |  H = Entropy (bits)  |  IG = Information Gain  |  Yellow = chosen split  |  Pink = rejected splits" style="text;html=1;strokeColor=#CCCCCC;fillColor=#F5F5F5;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#555555;" parent="1" vertex="1">
