                <mxCell id="ig_compare" value="&lt;b&gt;Information Gain Comparison (Step 1: Choose Root)&lt;/b&gt;&lt;br&gt;IG(Credit Score) = 0.971 − 0.361 = &lt;b&gt;0.610 ✓ HIGHEST → Root Node&lt;/b&gt;&lt;br&gt;IG(Income)       = 0.971 − 0.600 = 0.371&lt;br&gt;IG(Employed)     = 0.971 − 0.951 = 0.020" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontColor=#212121;fontSize=11;align=left;" parent="1" vertex="1">
