                <mxCell id="income_node" value="&lt;b&gt;Income&lt;/b&gt;&lt;br&gt;[5 instances: 4 Approve, 1 Deny]&lt;br&gt;H(good) = 0.722&lt;br&gt;IG(Income) = 0.722 − 0.000 = &lt;b&gt;0.722&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1565C0;strokeColor=#0D47A1;fontColor=#FFFFFF;fontSize=11;align=center;" parent="1" vertex="1">
