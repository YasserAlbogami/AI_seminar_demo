                <mxCell id="calc_sunny" value="&lt;b&gt;Sunny Branch Calculation:&lt;/b&gt;&lt;br&gt;5 inst: 2 Yes, 3 No&lt;br&gt;Try Humidity:&lt;br&gt;  high (3 inst): 0 Yes, 3 No → H=0.000&lt;br&gt;  normal (2 inst): 2 Yes, 0 No → H=0.000&lt;br&gt;Weighted H = (3/5)×0 + (2/5)×0 = 0.000&lt;br&gt;&lt;b&gt;IG(Humidity|sunny) = 0.971 − 0.000 = 0.971&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="20" y="870" width="380" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="calc_rain" value="&lt;b&gt;Rain Branch Calculation:&lt;/b&gt;&lt;br&gt;5 inst: 3 Yes, 2 No&lt;br&gt;Try Windy:&lt;br&gt;  false (3 inst): 3 Yes, 0 No → H=0.000&lt;br&gt;  true (2 inst): 0 Yes, 2 No → H=0.000&lt;br&gt;Weighted H = (3/5)×0 + (2/5)×0 = 0.000&lt;br&gt;&lt;b&gt;IG(Windy|rain) = 0.971 − 0.000 = 0.971&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontColor=#0D47A1;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="1250" y="870" width="380" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="calc_outlook" value="&lt;b&gt;Root Split IG Calculation — Outlook:&lt;/b&gt;&lt;br&gt;sunny (5/14): H = −(2/5)log₂(2/5) − (3/5)log₂(3/5) = 0.971&lt;br&gt;overcast (4/14): H = −(4/4)log₂(1) = 0.000  ← pure!&lt;br&gt;rain (5/14): H = −(3/5)log₂(3/5) − (2/5)log₂(2/5) = 0.971&lt;br&gt;Weighted Avg H = (5/14)×0.971 + (4/14)×0 + (5/14)×0.971 = 0.693&lt;br&gt;&lt;b&gt;IG(Outlook) = 0.940 − 0.693 = 0.247 ✓&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontColor=#212121;fontSize=10;align=left;" parent="1" vertex="1">
                    <mxGeometry x="430" y="870" width="800" height="130" as="geometry"/>
                </mxCell>
